<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.kafka</groupId>
  <artifactId>commit-log-producer</artifactId>
  <name>Kafka Commit Log Producer</name>
  <version>1.0.0</version>
  <description>CLI application that generates synthetic JSON events and publishes them
        to the Kafka commit-log topic for the Data Replication project.</description>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.2</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>com.kafka.producer.CommitLogProducer</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <maven.compiler.source>21</maven.compiler.source>
    <jackson.version>2.17.2</jackson.version>
    <kafka.version>4.0.0</kafka.version>
    <maven.compiler.target>21</maven.compiler.target>
    <slf4j.version>2.0.13</slf4j.version>
    <picocli.version>4.7.6</picocli.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <logback.version>1.5.6</logback.version>
  </properties>
</project>
